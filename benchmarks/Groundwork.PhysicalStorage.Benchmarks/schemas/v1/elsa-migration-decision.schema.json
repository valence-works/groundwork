{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ValenceWorks/Groundwork/benchmarks/physical-storage/v1/elsa-migration-decision.schema.json",
  "title": "Elsa Groundwork migration decision report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "mode",
    "baselineEligibility",
    "regressionDetected",
    "confirmationRequired",
    "cases",
    "regressions"
  ],
  "properties": {
    "schemaVersion": { "const": "groundwork.physical-storage.benchmark/v1" },
    "runId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["smoke", "scheduled"] },
    "baselineEligibility": { "$ref": "#/$defs/eligibility" },
    "regressionDetected": { "type": "boolean" },
    "confirmationRequired": { "type": "boolean" },
    "cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/case" }
    },
    "regressions": {
      "type": "array",
      "items": { "$ref": "#/$defs/regression" }
    }
  },
  "$defs": {
    "eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligible", "diagnostics"],
      "properties": {
        "eligible": { "type": "boolean" },
        "diagnostics": { "type": "array", "items": { "type": "string" } }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseIdentity",
        "provider",
        "storageForm",
        "workload",
        "latencyP50Nanoseconds",
        "latencyP95Nanoseconds",
        "latencyP99Nanoseconds",
        "throughputOperationsPerSecond",
        "allocatedBytesPerOperation",
        "planArtifact"
      ],
      "properties": {
        "caseIdentity": { "type": "string", "minLength": 1 },
        "provider": { "enum": ["sqlite", "sqlServer", "postgreSql", "mongoDb"] },
        "storageForm": { "enum": ["sharedDocuments", "dedicatedDocumentTable", "physicalEntityTable"] },
        "workload": { "type": "string", "minLength": 1 },
        "latencyP50Nanoseconds": { "type": "number", "exclusiveMinimum": 0 },
        "latencyP95Nanoseconds": { "type": "number", "exclusiveMinimum": 0 },
        "latencyP99Nanoseconds": { "type": "number", "exclusiveMinimum": 0 },
        "throughputOperationsPerSecond": { "type": "number", "exclusiveMinimum": 0 },
        "allocatedBytesPerOperation": { "type": "number", "minimum": 0 },
        "roundTripsPerOperation": { "type": ["number", "null"], "minimum": 0 },
        "storageGrowthBytes": { "type": ["integer", "null"], "minimum": 0 },
        "writeAmplificationBytesPerLogicalByte": { "type": ["number", "null"], "minimum": 0 },
        "physicalRowsPerLogicalMutation": { "type": ["number", "null"], "minimum": 0 },
        "planArtifact": { "type": "string", "minLength": 1 }
      }
    },
    "regression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseIdentity", "isComparable", "requiresConfirmation", "metrics", "diagnostics", "regressed"],
      "properties": {
        "caseIdentity": { "type": "string", "minLength": 1 },
        "isComparable": { "type": "boolean" },
        "requiresConfirmation": { "type": "boolean" },
        "metrics": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
        "diagnostics": { "type": "array", "items": { "type": "string" } },
        "regressed": { "type": "boolean" }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "direction",
        "baseline",
        "candidate",
        "ratio",
        "lowerConfidenceRatio",
        "upperConfidenceRatio",
        "budget",
        "regressed"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "direction": { "enum": ["lowerIsBetter", "higherIsBetter"] },
        "baseline": { "type": "number" },
        "candidate": { "type": "number" },
        "ratio": { "type": "number" },
        "lowerConfidenceRatio": { "type": "number" },
        "upperConfidenceRatio": { "type": "number" },
        "budget": { "type": "number", "minimum": 0 },
        "regressed": { "type": "boolean" }
      }
    }
  }
}
